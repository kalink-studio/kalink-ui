{
  "name": "@kalink-ui/canopy",
  "description": "A set of tools for building custom PayloadCMS experiences",
  "version": "1.0.0-beta.0",
  "private": false,
  "license": "MIT",
  "author": "Louis Gollut",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "https://github.com/kalink-studio/kalink-ui"
  },
  "sideEffects": [
    "**/*.css"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./client": {
      "types": "./dist/exports/client.d.ts",
      "import": "./dist/exports/client.js",
      "default": "./dist/exports/client.js"
    }
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "scripts": {
    "dev": "pnpm run build:assets && tsc -b --watch --preserveWatchOutput",
    "build": "pnpm run build:tsc && pnpm run build:assets",
    "rebuild": "pnpm run clean && pnpm run build",
    "build:assets": "node ./scripts/copy-css-assets.mjs",
    "build:tsc": "tsc -b",
    "clean": "node ./scripts/clean-dist.mjs",
    "prepare": "pnpm run rebuild",
    "lint": "eslint --max-warnings 0",
    "lint:fix": "pnpm lint --fix",
    "test": "vitest run --project=unit",
    "test:browser": "vitest run --project=browser",
    "test:watch": "vitest --project=unit",
    "tsc": "tsc -b"
  },
  "devDependencies": {
    "@kalink-ui/eslint-config": "workspace:*",
    "@kalink-ui/typescript-config": "workspace:*",
    "@payloadcms/next": "^3.79.0",
    "@payloadcms/richtext-lexical": "^3.79.0",
    "@payloadcms/ui": "^3.79.0",
    "next": "15.5.9",
    "@types/node": "^24.6.2",
    "@types/react": "19.2.7",
    "@types/react-dom": "19.2.3",
    "@testing-library/react": "^16.3.0",
    "@vitest/browser": "^4.0.16",
    "@vitest/browser-playwright": "^4.0.16",
    "@vitest/coverage-v8": "^4.0.16",
    "eslint": "^9.39.2",
    "payload": "^3.79.0",
    "playwright": "^1.57.0",
    "react": "^19.2.3",
    "typescript": "^5.9.3",
    "vite": "^7.3.0",
    "vite-tsconfig-paths": "^6.0.3",
    "vitest": "^4.0.16"
  },
  "peerDependencies": {
    "@payloadcms/richtext-lexical": "^3.58.0",
    "@payloadcms/ui": "^3.58.0",
    "payload": "^3.58.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "typescript": "^5.8.2"
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  }
}
