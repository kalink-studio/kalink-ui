    "lint:fix": "pnpm lint --fix",
    "tsc": "tsc -b"
  },
  "devDependencies": {
    "@kalink-ui/eslint-config": "workspace:*",
    "@kalink-ui/typescript-config": "workspace:*",
    "@types/node": "^24.6.2",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vanilla-extract/css": "^1.18.0",
    "@vanilla-extract/css-utils": "^0.1.6",
    "@vanilla-extract/recipes": "^0.5.7",
    "eslint": "^9.39.2",
    "type-fest": "^5.3.1",
    "typescript": "^5.9.3"
  },
  "peerDependencies": {
    "@vanilla-extract/css": "^1.17.4",
    "@vanilla-extract/css-utils": "^0.1.6",
    "@vanilla-extract/recipes": "^0.5.7",
    "typescript": "^5.9.3"
  },
  "publishConfig": {
    "access": "public"
  }
}
