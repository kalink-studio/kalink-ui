{
  "name": "@kalink-ui/seedly",
  "version": "1.0.0-beta.0",
  "description": "Vanilla-extract styles for Base UI component parity",
  "sideEffects": [
    "**/*.css.ts"
  ],
  "license": "MIT",
  "author": "Louis Gollut",
  "repository": {
    "type": "git",
    "url": "https://github.com/kalink-studio/kalink-ui"
  },
  "exports": {
    ".": "./src/index.ts",
    "./styles": "./src/styles/index.ts",
    "./styles/reset": "./src/styles/reset.css.ts",
    "./styles/layers": "./src/styles/layers.css.ts",
    "./styles/theme/base-ui": "./src/styles/theme/base-ui.css.ts",
    "./components": "./src/components/index.ts",
    "./components/*": "./src/components/*/index.ts"
