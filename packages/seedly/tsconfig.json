{
  "extends": "@kalink-ui/typescript-config/base.json",
  "include": ["src", "eslint.config.mts"],
  "exclude": ["node_modules"],
  "compilerOptions": {
    "noEmit": false,
    "incremental": true,
    "composite": true,
    "baseUrl": ".",
    "declaration": true,
    "emitDeclarationOnly": true,
    "outDir": "dist",
    "paths": {
      "@/*": ["./src/*"]
    }
  }
}
